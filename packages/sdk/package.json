{
  "name": "@vokda/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vokda TTS API — voice catalog + synthesis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
