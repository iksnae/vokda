{
  "name": "vokda",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "amplify:sandbox": "npx ampx sandbox",
    "amplify:deploy": "npx ampx pipeline-deploy --branch main",
    "amplify:outputs": "npx ampx generate outputs --format json --out-dir .",
    "build:web": "npm --workspace apps/web run build",
    "check:web": "npm --workspace apps/web run check",
    "lint": "npm --workspace apps/web run lint",
    "test": "npm --workspace apps/web run test"
  }
}
